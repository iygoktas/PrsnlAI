# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Connection string with pgBouncer for serverless (Next.js API routes)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Direct connection string used by Prisma Migrate (bypasses pgBouncer)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Embedding provider ───────────────────────────────────────────────────────
# "openai" (default) or "local" (Ollama)
EMBEDDING_PROVIDER="openai"

# Required when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY="sk-..."

# Required when EMBEDDING_PROVIDER=local
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# ─── LLM provider ─────────────────────────────────────────────────────────────
# "anthropic" (default) or "local" (Ollama)
LLM_PROVIDER="anthropic"

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Required when LLM_PROVIDER=local
OLLAMA_LLM_MODEL="llama3.2"

# ─── Chunking ─────────────────────────────────────────────────────────────────
MAX_CHUNK_SIZE="512"
CHUNK_OVERLAP="64"

# ─── Search ───────────────────────────────────────────────────────────────────
SEARCH_TOP_K="5"
SIMILARITY_THRESHOLD="0.70"

# ─── Logging ──────────────────────────────────────────────────────────────────
# "error" | "warn" | "info" | "debug"
LOG_LEVEL="info"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
